{
  "name": "codem",
  "version": "0.1.1",
  "description": "Cross-platform Codex usage meter",
  "author": "jinmiles <woojinkim@unist.ac.kr>",
  "type": "module",
  "main": "electron/main.cjs",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "check": "tsc --noEmit",
    "test": "npm run check && npm run electron:self-test",
    "test:local": "npm test",
    "test:tauri": "cargo test --manifest-path src-tauri/Cargo.toml",
    "electron": "npm run build && electron .",
    "electron:probe": "node electron/usage.cjs --fetch",
    "electron:run-check": "npm run build && CODEM_RUN_CHECK=1 electron .",
    "electron:self-test": "node electron/usage.cjs",
    "electron:build": "npm run build && electron-builder --linux AppImage deb --publish never",
    "tauri": "tauri",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.0.0",
    "vite": "^8.0.13"
  },
  "build": {
    "appId": "io.github.jinmiles.codem",
    "productName": "Codem",
    "directories": {
      "output": "release/electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "src-tauri/icons/icon.png",
      "package.json"
    ],
    "linux": {
      "artifactName": "${productName}-Electron-${version}-${arch}.${ext}",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "icon": "src-tauri/icons/icon.png"
    }
  }
}
