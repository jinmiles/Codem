{
  "compilerOptions": {
    "target": "ES2018",
    "module": "none",
    "strict": false,
    "noImplicitAny": false,
    "outFile": "build/extension.js",
    "removeComments": true,
    "lib": ["ES2018"]
  },
  "files": [
    "src/core/types.ts",
    "src/core/constants.ts",
    "src/core/format.ts",
    "src/core/usage.ts",
    "src/extension.ts"
  ],
  "exclude": ["node_modules"]
}
